# cp .env.example .env  (bootstrap이 자동 복사). 실제 비밀값은 .env에만 — 이 파일엔 넣지 말 것.

# --- API (apps/api) ---
DATABASE_URL="postgresql://postgres:postgresql@localhost:5432/markflow?schema=public"  # bootstrap Docker 기본값과 일치
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# Nodemailer SMTP Configuration (Gmail)
# SMTP_USER="본인구글이메일@gmail.com"
# SMTP_PASS="구글앱비밀번호16자리"

# --- Web (apps/web) ---
VITE_API_BASE="http://localhost:4000/api"
VITE_WS_URL="http://localhost:4000"

# --- Linear (git lb / /branch 자동 브랜치) ---
LINEAR_API_KEY=""   # Linear → Settings → API → Personal API key (개인 키 — .env에만)
