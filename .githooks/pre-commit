#!/usr/bin/env bash
# MarkFlow 공용 pre-commit 가드 — 도구 무관(Claude·자율 에이전트·사람 모두 적용).
# 등록: git config core.hooksPath .githooks  (./scripts/bootstrap이 자동 등록)
# 우회는 --no-verify로 가능하므로 보조 가드 — 최종 방어선은 GitHub 브랜치 보호 + PR 리뷰.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo '')"
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo "✖ '$branch'에 직접 커밋 금지 — feature 브랜치에서 작업하세요 (git lb <IEUM-id>)." >&2
  exit 1
fi

# 생성물·비밀 — 커밋 자체 금지 (dist · node_modules · .env*). 단 .env.example은 추적 파일이므로 허용.
gen="$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '(^|/)dist/|(^|/)node_modules/|(^|/)\.env($|\.)' \
  | grep -vE '(^|/)\.env\.example$' || true)"
if [ -n "$gen" ]; then
  echo "✖ 생성물/비밀 파일은 커밋 금지 (dist·node_modules·.env):" >&2
  echo "$gen" | sed 's/^/   - /' >&2
  exit 1
fi

# 기존 Prisma 마이그레이션 수정/삭제 금지 (새 마이그레이션 '추가'는 허용)
mig="$(git diff --cached --name-only --diff-filter=MD -- 'apps/api/prisma/migrations/' || true)"
if [ -n "$mig" ]; then
  echo "✖ 기존 Prisma 마이그레이션 수정/삭제 금지 (새 마이그레이션 추가만 허용):" >&2
  echo "$mig" | sed 's/^/   - /' >&2
  exit 1
fi

# 역할별 스코프 가드 — Claude의 .claude/settings.local.json과 동일 효과를 모든 도구(자율 에이전트 포함)에.
# 역할 설정: ./scripts/set-role.sh <BE|F1|F2> (git config markflow.role 기록). 미설정 시 건너뜀.
role="$(git config markflow.role 2>/dev/null || echo '')"
case "$role" in
  BE) forbidden='^apps/web/'; label='apps/web (F1/F2 영역)' ;;
  F1 | F2 | FE) forbidden='^apps/api/'; label='apps/api·prisma (BE 영역)' ;;
  *) forbidden='' ;;
esac
if [ -n "$forbidden" ]; then
  oos="$(git diff --cached --name-only --diff-filter=ACMR | grep -E "$forbidden" || true)"
  if [ -n "$oos" ]; then
    echo "✖ 역할 '$role' 범위 밖 파일 커밋 차단 — $label:" >&2
    echo "$oos" | sed 's/^/   - /' >&2
    echo "   (경계를 넘는 변경이 의도된 거면 멈추고 보고 · 역할 변경: ./scripts/set-role.sh <BE|F1|F2>)" >&2
    exit 1
  fi
fi

exit 0
