{
  "name": "@markflow/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch --exec \"node --env-file=../../.env\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --env-file=../../.env",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@markflow/shared": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/platform-socket.io": "^10.4.4",
    "@nestjs/websockets": "^10.4.4",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^10.4.4",
    "@swc/core": "^1.3.62",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "prisma": "^5.18.0",
    "socket.io-client": "^4.7.5",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.2.6"
  }
}
